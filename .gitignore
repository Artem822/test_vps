version: "3.9"

services:
  backend:
    build:
      context: ./backend
    container_name: hosting-tester-backend
    environment:
      PORT: 8080
      APP_VERSION: 1.0.0
    expose:
      - "8080"

  frontend:
    build:
      context: ./frontend
    container_name: hosting-tester-frontend
    environment:
      BACKEND_INTERNAL_URL: http://backend:8080
    ports:
      - "3000:3000"
    depends_on:
      - backend